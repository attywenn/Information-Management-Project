**[tailwind.css]**

@import "tailwindcss";

@theme {
  --color-brand-red: #dc2626;      /* A more vibrant, accessible red */
  --color-brand-dark: #991b1b;     /* Refined dark red for hover states */
  --font-sans: "Manrope", "Segoe UI", sans-serif;
}

@layer base {
  :root {
    color-scheme: light;
  }

  html[data-theme="dark"] {
    color-scheme: dark;
  }

  body {
    font-family: "Manrope", "Segoe UI", sans-serif;
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    background-color: #f8fafc;
    color: #1e293b;
  }

  html[data-theme="dark"] body {
    background-color: #020617;
    color: #f1f5f9;
  }

  html[data-theme="dark"] .bg-white {
    background-color: #0f172a !important;
  }

  html[data-theme="dark"] .bg-slate-50,
  html[data-theme="dark"] .bg-slate-50\/50,
  html[data-theme="dark"] .bg-slate-50\/70 {
    background-color: #0f172a !important;
  }

  html[data-theme="dark"] .bg-slate-100 {
    background-color: #1e293b !important;
  }

  html[data-theme="dark"] .text-slate-900,
  html[data-theme="dark"] .text-slate-800,
  html[data-theme="dark"] .text-slate-700 {
    color: #f1f5f9 !important;
  }

  html[data-theme="dark"] .text-slate-600,
  html[data-theme="dark"] .text-slate-500,
  html[data-theme="dark"] .text-slate-400 {
    color: #cbd5e1 !important;
  }

  html[data-theme="dark"] .border-slate-100,
  html[data-theme="dark"] .border-slate-200,
  html[data-theme="dark"] .border-slate-300 {
    border-color: #334155 !important;
  }

  html[data-theme="dark"] input,
  html[data-theme="dark"] select,
  html[data-theme="dark"] textarea {
    background-color: #1e293b;
    color: #f1f5f9;
    border-color: #475569;
  }

  html[data-theme="dark"] .hover\:bg-slate-50:hover {
    background-color: #1e293b !important;
  }
}

@layer components {
  .dashboard-modern {
    background:
      radial-gradient(1200px 500px at -10% -10%, rgba(251, 113, 133, 0.15), transparent 60%),
      radial-gradient(1000px 500px at 110% 0%, rgba(56, 189, 248, 0.14), transparent 60%),
      linear-gradient(180deg, #f8fbff 0%, #f8fafc 60%, #f1f5f9 100%);
  }

  .dashboard-main {
    scrollbar-gutter: stable;
  }

  .dashboard-modern :is(.bg-white.rounded-2xl, .bg-white.rounded-3xl, .bg-white\/90.rounded-2xl) {
    border-color: rgba(148, 163, 184, 0.32) !important;
    box-shadow: 0 10px 30px -18px rgba(15, 23, 42, 0.35);
  }

  .dashboard-modern .shadow-sm {
    box-shadow: 0 8px 24px -20px rgba(15, 23, 42, 0.4);
  }

  .dashboard-modern h1 {
    letter-spacing: -0.02em;
  }

  .dashboard-modern :is(input, select, textarea) {
    border-radius: 0.75rem;
  }

  .dashboard-modern button {
    transition: transform 180ms ease, box-shadow 180ms ease, background-color 180ms ease, border-color 180ms ease, color 180ms ease;
  }

  .dashboard-modern button:hover {
    transform: translateY(-1px);
  }

  .dashboard-modern .max-h-130 {
    max-height: min(70vh, 40rem);
  }
}

@media (max-width: 1023px) {
  .dashboard-main {
    padding-top: 5rem;
    padding-bottom: 5.5rem;
  }

  .dashboard-modern .rounded-2xl,
  .dashboard-modern .rounded-3xl {
    border-radius: 1rem;
  }
}

@media (max-width: 767px) {
  .dashboard-main {
    padding-left: 0.9rem;
    padding-right: 0.9rem;
  }

  .dashboard-modern :is(h1.text-3xl, h2.text-2xl) {
    font-size: 1.6rem;
    line-height: 1.2;
  }

  .dashboard-modern .p-6 {
    padding: 1rem;
  }
}

